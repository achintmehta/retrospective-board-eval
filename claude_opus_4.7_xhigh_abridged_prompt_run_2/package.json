{
  "name": "retro-board",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted real-time retrospective board with WebSockets and SQLite.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build && tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "nanoid": "^5.0.7",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
