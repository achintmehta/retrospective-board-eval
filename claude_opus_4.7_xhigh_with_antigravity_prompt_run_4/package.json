{
  "name": "retro-board",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted real-time retrospective board",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch src --ext js,sql --exec \"node --experimental-sqlite src/server.js\"",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node --experimental-sqlite src/server.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "nanoid": "^5.0.7",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
