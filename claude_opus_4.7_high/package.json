{
  "name": "retro-board",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted real-time retrospective board",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:client && npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "npm --prefix client install && npm --prefix client run build",
    "start": "node dist/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
