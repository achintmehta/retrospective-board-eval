{
  "name": "retro-board",
  "version": "1.0.0",
  "description": "Real-time retrospective board with WebSocket collaboration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"npm run dev --prefix client\"",
    "build": "tsc && npm run build --prefix client",
    "start": "node dist/index.js",
    "server:dev": "tsx watch server/index.ts"
  },
  "keywords": ["retrospective", "realtime", "collaboration"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
