{
  "name": "retro-board",
  "version": "1.0.0",
  "description": "Real-time self-hosted retrospective board with WebSockets and SQLite.",
  "private": true,
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "build:client": "npm --prefix client install && npm --prefix client run build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3"
  }
}
