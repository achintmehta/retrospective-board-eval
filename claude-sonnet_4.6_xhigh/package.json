{
  "name": "retro-board",
  "version": "1.0.0",
  "description": "Real-time retrospective board",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"nodemon src/server.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "serve": "NODE_ENV=production node src/server.js"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
