{
  "name": "retro-board",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"node --watch server/index.js\" \"cd client && npm run dev\"",
    "start": "node server/index.js",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
