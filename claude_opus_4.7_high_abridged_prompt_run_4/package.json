{
  "name": "retro-board",
  "version": "1.0.0",
  "description": "Self-hosted real-time retrospective board",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch server server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "nanoid": "^5.0.7",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=22.5"
  }
}
