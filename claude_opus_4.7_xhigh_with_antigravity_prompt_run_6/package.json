{
  "name": "realtime-retro-board",
  "version": "1.0.0",
  "description": "Self-hosted real-time retrospective board with Node.js, Express, Socket.io, SQLite, and React.",
  "type": "module",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch server --ext js,sql --exec node server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
