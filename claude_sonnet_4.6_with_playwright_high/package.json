{
  "name": "retro-board",
  "version": "1.0.0",
  "description": "Real-time retrospective board",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev:server": "nodemon src/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start:prod": "npm run build && node src/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
