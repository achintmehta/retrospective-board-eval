{
  "name": "retro-board",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time, self-hosted retrospective board (Express + Socket.io + SQLite + React/Vite)",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch server --ext js,json server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "nanoid": "^5.0.7",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=22.5"
  }
}
