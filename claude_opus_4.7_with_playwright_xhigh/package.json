{
  "name": "realtime-retro-board",
  "version": "1.0.0",
  "private": true,
  "description": "A self-hosted real-time retrospective board with Node.js, React, Socket.io, and SQLite.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "npm --prefix client install && npm --prefix client run build",
    "start": "cross-env NODE_ENV=production node server/dist/index.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
