{
  "name": "realtime-retro-board",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted real-time retrospective board",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch server server/index.js",
    "dev:client": "npm --prefix client run dev",
    "start": "node server/index.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "install:all": "npm install && npm --prefix client install"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7"
  }
}
