{
  "name": "realtime-retro-board",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted real-time retrospective board with collaborative cards, comments, and CSV export.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch src --watch server.js server.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "nanoid": "^3.3.7",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7"
  }
}
